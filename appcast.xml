<?xml version="1.0" encoding="utf-8"?>
<!--
  iNotes Sparkle appcast — DIRECT-DOWNLOAD BUILD ONLY.

  This is a TEMPLATE with one example <item>. It is not a real release feed
  yet: the enclosure URL, length, and edSignature below are placeholders.
  `scripts/release.sh` shows how a real release appends/updates an <item>
  here. See DISTRIBUTION.md for hosting instructions (SUFeedURL in
  iNotes/Info.plist currently points at a placeholder GitHub raw URL and
  must be repointed to wherever this file actually ends up).
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle">
  <channel>
    <title>iNotes Updates</title>
    <link>https://raw.githubusercontent.com/spacegrowth/inotes/main/appcast.xml</link>
    <description>Direct-download update feed for iNotes.</description>
    <language>en</language>

    <!--
      No published releases yet. This is intentionally an EMPTY feed: while it
      contains no <item>, Sparkle reports "You're up to date" (no error).
      `scripts/release.sh` appends a real <item> here on each release — see the
      commented example below for the exact shape it produces.

      <item>
        <title>Version X.Y</title>
        <pubDate>…RFC-822 date…</pubDate>
        <sparkle:version>BUILD_NUMBER</sparkle:version>
        <sparkle:shortVersionString>X.Y</sparkle:shortVersionString>
        <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
        <enclosure url="…/iNotes-X.Y.zip" length="BYTES"
          type="application/octet-stream"
          sparkle:edSignature="…from sign_update…" />
      </item>
    -->
  </channel>
</rss>
